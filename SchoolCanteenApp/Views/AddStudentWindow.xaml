<Window x:Class="SchoolCanteenApp.Views.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SchoolCanteenApp.Views"
        mc:Ignorable="d"
        Title="AddStudentWindow" Height="450" Width="800">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Имя"/>
            <TextBox Text="{Binding FirstName}"/>

            <TextBlock Text="Фамилия"/>
            <TextBox Text="{Binding LastName}"/>

            <TextBlock Text="Класс"/>
            <ComboBox x:Name="ClassComboBox" 
                      SelectedValue="{Binding IdClass}"
                      DisplayMemberPath="Class1"
                      SelectedValuePath="IdClass"/>

            <Button Content="Сохранить" Click="SaveButton_Click" Margin="0 10"/>
        </StackPanel>
    </Grid>
</Window>
